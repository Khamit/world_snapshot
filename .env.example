# .env.example - НЕ СОДЕРЖИТ РЕАЛЬНЫХ КЛЮЧЕЙ!
ADMIN_TOKEN=change-this-in-production
FRONTEND_URL=http://localhost:5173

# API Keys (замените на свои в Render Dashboard)
GNEWS_API_KEY=your-gnews-api-key-here
NEWSDATA_API_KEY=your-newsdata-api-key-here

# Server
PORT=3000

# Email alerts (опционально)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL=admin@yourdomain.com
LOG_LEVEL=info